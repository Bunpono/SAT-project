# Create SAT/backend/.env from this file and replace the placeholder locally.
# Never commit the real token.
HF_TOKEN=hf_your_hugging_face_token_here

# Hugging Face repository containing the complete tokenizer and model weights.
HF_MODEL_ID=SAT-Project/SAT-Model-T1

# Optional local cache. The default is SAT/backend/.cache/huggingface.
HF_MODEL_CACHE_DIR=.cache/huggingface

# Deployed frontend origin with no path. Separate multiple origins with commas.
FRONTEND_URL=https://your-project.vercel.app

# Local user accounts stay in this database. This may be SQLite during local
# development; analyzed sentences are saved to Supabase through its REST API.
DATABASE_URL=sqlite:///sat.db

# Supabase Project Settings > API. Keep the secret key on the backend only;
# never use a VITE_ variable or commit the real value.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SECRET_KEY=sb_secret_your_secret_key

# Generate a long random value and keep it only in the deployment environment.
JWT_SECRET_KEY=replace_with_a_long_random_secret
